# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY web/package.json web/package-lock.json ./

RUN npm ci

COPY web . .

RUN npm run build

# Production stage
FROM node:20-alpine

WORKDIR /app

# Install serve to run the built app
RUN npm install -g serve

COPY --from=builder /app/dist ./dist

EXPOSE 5173

CMD ["serve", "-s", "dist", "-l", "5173"]
