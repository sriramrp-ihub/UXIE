APP_NAME=LMS Backend
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false

DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>:5432/<db>
REDIS_URL=redis://<host>:6379/0

JWT_SECRET_KEY=<strong-secret>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
VERIFICATION_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_VERIFY_URL=http://localhost:8000/api/v1/auth/verify
SCORM_STORAGE_DIR=storage/scorm

CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=180
CACHE_TTL_LONG=300
ACTIVE_USER_WINDOW_SECONDS=900
